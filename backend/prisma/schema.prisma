generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                      String   @id @default(cuid())
  openid                  String?  @unique
  unionid                 String?
  nickname                String?
  avatarUrl               String?
  phone                   String?
  registeredAt            DateTime @default(now())
  lastLoginAt             DateTime?
  loginIp                 String?
  status                  String   @default("active")
  currentMembershipStatus String   @default("none")
  currentPoints           Int      @default(0)
  totalAnalysisCount      Int      @default(0)
  totalRechargeAmount     Decimal  @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  sessions        UserSession[]
  memberships     UserMembership[]
  wallet          UserWallet?
  pointLedger     PointLedger[]
  paymentOrders   PaymentOrder[]
  analysisRecords AnalysisRecord[]
  requestLogs     RequestLog[]

  @@index([unionid])
  @@index([status])
  @@index([registeredAt])
  @@map("users")
}

model UserSession {
  id              String   @id @default(cuid())
  userId          String
  sessionToken    String?  @unique
  deviceId        String?
  platform        String?
  ip              String?
  userAgent       String?
  lastHeartbeatAt DateTime @default(now())
  onlineStatus    String   @default("online")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([lastHeartbeatAt])
  @@index([onlineStatus])
  @@map("user_sessions")
}

model MembershipPlan {
  id             String   @id @default(cuid())
  name           String
  price          Decimal
  durationDays   Int
  analysisLimit  Int      @default(0)
  unlimited      Boolean  @default(false)
  description    String?
  sortOrder      Int      @default(0)
  enabled        Boolean  @default(true)
  createdBy      String?
  updatedBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  memberships UserMembership[]

  @@index([enabled, sortOrder])
  @@map("membership_plans")
}

model UserMembership {
  id                 String   @id @default(cuid())
  userId             String
  planId             String
  orderId            String?  @unique
  startAt            DateTime
  endAt              DateTime
  status             String   @default("active")
  analysisLimit      Int      @default(0)
  analysisUsed       Int      @default(0)
  unlimited          Boolean  @default(false)
  purchaseMode       String   @default("renew_stack")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user  User           @relation(fields: [userId], references: [id])
  plan  MembershipPlan @relation(fields: [planId], references: [id])
  order PaymentOrder?  @relation(fields: [orderId], references: [id])

  @@index([userId, status])
  @@index([endAt])
  @@map("user_memberships")
}

model PointPackage {
  id          String   @id @default(cuid())
  name        String
  price       Decimal
  points      Int
  bonusPoints Int      @default(0)
  description String?
  sortOrder   Int      @default(0)
  enabled     Boolean  @default(true)
  createdBy   String?
  updatedBy   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([enabled, sortOrder])
  @@map("point_packages")
}

model UserWallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  pointsBalance  Int      @default(0)
  frozenPoints   Int      @default(0)
  totalEarned    Int      @default(0)
  totalSpent     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@map("user_wallets")
}

model PointLedger {
  id              String   @id @default(cuid())
  userId          String
  walletId        String?
  orderId         String?
  analysisRecordId String?
  changeType      String
  direction       String
  points          Int
  beforeBalance   Int
  afterBalance    Int
  remark          String?
  operatorType    String   @default("system")
  operatorId      String?
  createdAt       DateTime @default(now())

  user          User            @relation(fields: [userId], references: [id])
  order         PaymentOrder?    @relation(fields: [orderId], references: [id])
  analysisRecord AnalysisRecord? @relation(fields: [analysisRecordId], references: [id])

  @@index([userId, createdAt])
  @@index([orderId])
  @@index([analysisRecordId])
  @@index([changeType])
  @@map("point_ledger")
}

model PaymentOrder {
  id                    String    @id @default(cuid())
  orderNo               String    @unique
  userId                String
  orderType             String
  productId             String
  productName           String?
  amount                Decimal
  currency              String    @default("CNY")
  status                String    @default("pending")
  paymentProvider       String?
  thirdPartyTradeNo     String?
  paidAt                DateTime?
  callbackRaw           String?
  callbackSignature     String?
  callbackProcessedAt   DateTime?
  refundedAt            DateTime?
  refundAmount          Decimal?
  failReason            String?
  clientIp              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user            User              @relation(fields: [userId], references: [id])
  membership      UserMembership?
  pointLedger     PointLedger[]

  @@index([userId, createdAt])
  @@index([orderType, status])
  @@index([thirdPartyTradeNo])
  @@index([createdAt])
  @@map("payment_orders")
}

model AnalysisRecord {
  id                  String   @id @default(cuid())
  userId              String
  submitContent       String
  imageUrl            String?
  birthInfoJson       String
  baziResultJson      String
  aiResult            String?
  promptVersionId     String?
  pointsCost          Int      @default(0)
  memberFree          Boolean  @default(false)
  analysisType        String
  durationMs          Int?
  success             Boolean  @default(false)
  failReason          String?
  clientIp            String?
  createdAt           DateTime @default(now())

  user          User             @relation(fields: [userId], references: [id])
  promptVersion PromptVersion?   @relation(fields: [promptVersionId], references: [id])
  pointLedger   PointLedger[]

  @@index([userId, createdAt])
  @@index([analysisType, createdAt])
  @@index([success])
  @@map("analysis_records")
}

model PromptVersion {
  id              String   @id @default(cuid())
  title           String
  content         String
  versionNo       Int
  status          String   @default("draft")
  changeReason    String?
  baseVersionId   String?
  baseVersionNo   Int?
  createdBy       String?
  activatedBy     String?
  activatedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  analysisRecords AnalysisRecord[]

  @@unique([versionNo])
  @@index([status])
  @@map("prompt_versions")
}

model PromptSuggestion {
  id                 String   @id @default(cuid())
  questionType       String
  userNeed           String
  currentWeakness    String
  addRules           String
  removeRules        String?
  recommendedSnippet String
  sampleRecordIds    String?
  status             String   @default("pending")
  generatedBy        String   @default("system")
  reviewedBy         String?
  reviewedAt         DateTime?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([status, createdAt])
  @@map("prompt_suggestions")
}

model RequestLog {
  id             String   @id @default(cuid())
  userId         String?
  ip             String
  path           String
  method         String
  userAgent      String?
  statusCode     Int
  durationMs     Int
  requestTime    DateTime @default(now())
  requestId      String?
  rateLimited    Boolean  @default(false)
  blockedByBlacklist Boolean @default(false)
  requestBodyBytes Int?
  provider       String?
  country        String?
  region         String?
  city           String?

  user User? @relation(fields: [userId], references: [id])

  @@index([ip, requestTime])
  @@index([path, requestTime])
  @@index([statusCode, requestTime])
  @@index([userId, requestTime])
  @@map("request_logs")
}

model SecurityEvent {
  id              String   @id @default(cuid())
  eventType       String
  attackIp        String
  requestCount    Int      @default(0)
  attackPath      String?
  firstSeenAt     DateTime
  lastSeenAt      DateTime
  status          String   @default("open")
  sourceProvider  String?
  rawData         String?
  handledBy       String?
  handledAt       DateTime?
  note            String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([eventType, status])
  @@index([attackIp, lastSeenAt])
  @@map("security_events")
}

model IpBlocklist {
  id        String   @id @default(cuid())
  ip        String   @unique
  reason    String?
  status    String   @default("active")
  createdBy String?
  expiresAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, expiresAt])
  @@map("ip_blocklist")
}

model AdminUser {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  nickname     String?
  role         String
  status       String   @default("active")
  lastLoginAt  DateTime?
  lastLoginIp  String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  auditLogs AdminAuditLog[]

  @@index([role, status])
  @@map("admin_users")
}

model AdminAuditLog {
  id          String   @id @default(cuid())
  adminId     String?
  action      String
  resource    String
  resourceId  String?
  beforeJson  String?
  afterJson   String?
  ip          String?
  userAgent   String?
  createdAt   DateTime @default(now())

  admin AdminUser? @relation(fields: [adminId], references: [id])

  @@index([adminId, createdAt])
  @@index([resource, resourceId])
  @@map("admin_audit_logs")
}

model DashboardDailyStat {
  id              String   @id @default(cuid())
  statDate        DateTime @unique
  newUsers        Int      @default(0)
  activeUsers     Int      @default(0)
  analysisCount   Int      @default(0)
  rechargeAmount  Decimal  @default(0)
  paidOrderCount  Int      @default(0)
  abnormalRequests Int     @default(0)
  suspectedAttacks Int     @default(0)
  memberUsers      Int     @default(0)
  pointRechargeUsers Int   @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@map("dashboard_daily_stats")
}

model DashboardHourlyStat {
  id              String   @id @default(cuid())
  statHour        DateTime @unique
  newUsers        Int      @default(0)
  activeUsers     Int      @default(0)
  analysisCount   Int      @default(0)
  rechargeAmount  Decimal  @default(0)
  requestCount    Int      @default(0)
  abnormalRequests Int     @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([statHour])
  @@map("dashboard_hourly_stats")
}
